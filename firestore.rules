rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Daily insights (read-only from client, written by Cloud Functions)
      match /dailyInsights/{insightId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; // Only Cloud Functions can write
      }
    }

    // Anonymous onboarding data (pre-auth, keyed by UUID session ID)
    // Reads require auth — migration runs post-auth so request.auth is always set.
    // Writes are capped at 15 fields to prevent large payload injection.
    match /onboarding/anonymous/users/{sessionId} {
      allow read, delete: if request.auth != null;
      allow write: if request.resource.data.size() <= 15;
    }
  }
}
